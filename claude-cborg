#!/bin/bash

CBORG_MODEL=cborg-coder
CBORG_MODEL_MAX_OUTPUT_TOKENS=16384

export ANTHROPIC_BASE_URL=https://api.cborg.lbl.gov
export ANTHROPIC_AUTH_TOKEN=$CBORG_API_KEY
export ANTHROPIC_DEFAULT_HAIKU_MODEL=$CBORG_MODEL
export ANTHROPIC_DEFAULT_SONNET_MODEL=$CBORG_MODEL
export ANTHROPIC_DEFAULT_OPUS_MODEL=$CBORG_MODEL
export ANTHROPIC_MODEL=$CBORG_MODEL
export CLAUDE_CODE_SUBAGENT_MODEL=$CBORG_MODEL
export CLAUDE_CODE_MAX_OUTPUT_TOKENS=16384

exec claude "$@"
