#!/bin/bash

export ANTHROPIC_BASE_URL=https://api.cborg.lbl.gov
export ANTHROPIC_AUTH_TOKEN=$CBORG_API_KEY

export ANTHROPIC_DEFAULT_HAIKU_MODEL=anthropic/claude-haiku-4-5
export ANTHROPIC_DEFAULT_SONNET_MODEL=anthropic/claude-sonnet
export ANTHROPIC_DEFAULT_OPUS_MODEL=anthropic/claude-opus-4-8

export ANTHROPIC_MODEL=$ANTHROPIC_DEFAULT_SONNET_MODEL
export CLAUDE_CODE_SUBAGENT_MODEL=$ANTHROPIC_DEFAULT_HAIKU_MODEL

export DISABLE_NON_ESSENTIAL_MODEL_CALLS=1
export DISABLE_TELEMETRY=1
export CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1
export CLAUDE_CODE_MAX_OUTPUT_TOKENS=8192

exec claude "$@"
